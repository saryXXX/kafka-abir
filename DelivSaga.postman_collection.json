{
  "info": {
    "_postman_id": "ea5a298b-70c8-47bc-8d99-31ff833bfa89",
    "name": "DelivSaga API Collection",
    "description": "Postman collection to test the REST and GraphQL endpoints of the DelivSaga Smart Food Delivery microservices monorepo.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
