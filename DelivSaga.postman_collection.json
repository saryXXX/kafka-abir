  "item": [
    {
      "name": "REST API Endpoints",
      "item": [
        {
          "name": "Get All Restaurants",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/restaurants",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "restaurants"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response returns restaurants array\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.restaurants).to.be.an('array');",
                  "    pm.expect(jsonData.restaurants.length).to.be.above(0);",
                  "    ",
                  "    // Save first restaurant ID for next requests",
                  "    pm.collectionVariables.set(\"restaurant_id\", jsonData.restaurants[0].id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Restaurant Menu",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/restaurants/{{restaurant_id}}/menu",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "restaurants",
                "{{restaurant_id}}",
                "menu"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response contains menu items\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.items).to.be.an('array');",
                  "    pm.expect(jsonData.items.length).to.be.above(0);",
                  "    pm.collectionVariables.set(\"menu_item_id\", jsonData.items[0].id);",
                  "    pm.collectionVariables.set(\"menu_item_name\", jsonData.items[0].name);",
                  "    pm.collectionVariables.set(\"menu_item_price\", jsonData.items[0].price);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Create Order (REST)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"user_postman\",\n  \"restaurant_id\": \"{{restaurant_id}}\",\n  \"items\": [\n    {\n      \"item_id\": \"{{menu_item_id}}\",\n      \"name\": \"{{menu_item_name}}\",\n      \"quantity\": 2,\n      \"price\": {{menu_item_price}}\n    }\n  ],\n  \"delivery_address\": \"123 Postman St, Tunis\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/orders",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "orders"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Order successfully created\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.id).to.exist;",
                  "    pm.expect(jsonData.status).to.eql(\"PENDING\");",
                  "    pm.collectionVariables.set(\"rest_order_id\", jsonData.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Order Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/orders/{{rest_order_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "orders",
                "{{rest_order_id}}"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Order properties are correct\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.id).to.eql(pm.collectionVariables.get(\"rest_order_id\"));",
                  "    pm.expect(jsonData.status).to.be.oneOf([\"PENDING\", \"RESTAURANT_APPROVED\", \"PREPARING\", \"EN_ROUTE\", \"DELIVERED\"]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
