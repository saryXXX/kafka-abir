    {
      "name": "GraphQL API Endpoints",
      "item": [
        {
          "name": "Query Restaurants",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query GetRestaurants {\n  restaurants {\n    id\n    name\n    cuisine\n    address\n    isOpen\n    menu {\n      id\n      name\n      price\n      available\n    }\n  }\n}",
                "variables": ""
              }
            },
            "url": {
              "raw": "{{base_url}}/graphql",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "graphql"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"GraphQL response has restaurants list\", function () {",
                  "    var response = pm.response.json();",
                  "    pm.expect(response.errors).to.not.exist;",
                  "    pm.expect(response.data.restaurants).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Mutation Create Order (GraphQL)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation CreateOrder($userId: String!, $restaurantId: String!, $items: [OrderItemInput!]!, $deliveryAddress: String!) {\n  createOrder(user_id: $userId, restaurant_id: $restaurantId, items: $items, delivery_address: $deliveryAddress) {\n    id\n    status\n    total_price\n    created_at\n  }\n}",
                "variables": "{\n  \"userId\": \"user_postman_gql\",\n  \"restaurantId\": \"{{restaurant_id}}\",\n  \"items\": [\n    {\n      \"itemId\": \"{{menu_item_id}}\",\n      \"name\": \"{{menu_item_name}}\",\n      \"quantity\": 1,\n      \"price\": {{menu_item_price}}\n    }\n  ],\n  \"deliveryAddress\": \"456 GraphQL Ave, Tunis\"\n}"
              }
            },
            "url": {
              "raw": "{{base_url}}/graphql",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "graphql"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"GraphQL Order created successfully\", function () {",
                  "    var response = pm.response.json();",
                  "    pm.expect(response.errors).to.not.exist;",
                  "    pm.expect(response.data.createOrder.id).to.exist;",
                  "    pm.collectionVariables.set(\"gql_order_id\", response.data.createOrder.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Query Order Tracking (GraphQL)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query GetOrder($id: ID!) {\n  order(id: $id) {\n    id\n    status\n    totalPrice\n    items {\n      name\n      quantity\n    }\n    delivery {\n      driverName\n      status\n      eta\n    }\n  }\n}",
                "variables": "{\n  \"id\": \"{{gql_order_id}}\"\n}"
              }
            },
            "url": {
              "raw": "{{base_url}}/graphql",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "graphql"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"GraphQL order matches requirements\", function () {",
                  "    var response = pm.response.json();",
                  "    pm.expect(response.errors).to.not.exist;",
                  "    pm.expect(response.data.order.id).to.eql(pm.collectionVariables.get(\"gql_order_id\"));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Mutation Register Driver (GraphQL)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation RegisterDriver($name: String!, $vehicle: String!) {\n  registerDriver(name: $name, vehicle: $vehicle) {\n    id\n    name\n    vehicle\n    status\n  }\n}",
                "variables": "{\n  \"name\": \"Chokri GraphQL\",\n  \"vehicle\": \"Motorcycle\"\n}"
              }
            },
            "url": {
              "raw": "{{base_url}}/graphql",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "graphql"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"GraphQL Driver registered correctly\", function () {",
                  "    var response = pm.response.json();",
                  "    pm.expect(response.errors).to.not.exist;",
                  "    pm.expect(response.data.registerDriver.name).to.eql(\"Chokri GraphQL\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Mutation Update Location (GraphQL)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation UpdateLocation($driverId: ID!, $lat: Float!, $lng: Float!) {\n  updateDriverLocation(driverId: $driverId, lat: $lat, lng: $lng)\n}",
                "variables": "{\n  \"driverId\": \"{{driver_id}}\",\n  \"lat\": 36.8123,\n  \"lng\": 10.1982\n}"
              }
            },
            "url": {
              "raw": "{{base_url}}/graphql",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "graphql"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"GraphQL location coordinates updated\", function () {",
                  "    var response = pm.response.json();",
                  "    pm.expect(response.errors).to.not.exist;",
                  "    pm.expect(response.data.updateDriverLocation).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
